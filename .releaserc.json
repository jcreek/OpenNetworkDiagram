{
	"branches": ["main"],
	"tagFormat": "v${version}",
	"plugins": [
		[
			"@semantic-release/commit-analyzer",
			{
				"preset": "conventionalcommits",
				"releaseRules": [
					{
						"type": "build",
						"release": "patch"
					},
					{
						"type": "chore",
						"release": "patch"
					},
					{
						"type": "ci",
						"release": "patch"
					},
					{
						"type": "docs",
						"release": "patch"
					},
					{
						"type": "refactor",
						"release": "patch"
					},
					{
						"type": "style",
						"release": "patch"
					},
					{
						"type": "test",
						"release": "patch"
					}
				]
			}
		],
		[
			"@semantic-release/release-notes-generator",
			{
				"preset": "conventionalcommits",
				"presetConfig": {
					"types": [
						{
							"type": "build",
							"section": "Build"
						},
						{
							"type": "chore",
							"section": "Chores"
						},
						{
							"type": "ci",
							"section": "CI"
						},
						{
							"type": "docs",
							"section": "Docs"
						},
						{
							"type": "refactor",
							"section": "Refactors"
						},
						{
							"type": "style",
							"section": "Style"
						},
						{
							"type": "test",
							"section": "Tests"
						}
					]
				}
			}
		],
		"@semantic-release/github"
	]
}
